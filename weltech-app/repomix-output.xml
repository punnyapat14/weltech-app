                                        </div>
                                        <div>
                                            <h3 className={`font-bold text-sm ${theme === 'dark' ? 'text-gray-100' : 'text-gray-800'}`}>{article.author_name}</h3>
                                            <div className="text-xs text-gray-500">{formatTime(article.created_at)}</div>
