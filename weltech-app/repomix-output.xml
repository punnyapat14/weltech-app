<file path="Dockerfile">
# ใช้ Python 3.9 เป็นพื้นฐาน
FROM python:3.9-slim

# สร้าง User ใหม่เพื่อความปลอดภัยตามกฎของ Hugging Face
RUN useradd -m -u 1000 user
USER user
ENV PATH="/home/user/.local/bin:$PATH"

# กำหนดโฟลเดอร์ทำงาน
WORKDIR /app

# คัดลอกไฟล์ requirements และติดตั้งแพ็กเกจ
COPY --chown=user requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# คัดลอกไฟล์ทั้งหมด (server.py, best.pt) เข้าไปใน Docker
COPY --chown=user . .

# เปิด Port 7860 (Hugging Face บังคับใช้ Port นี้)
EXPOSE 7860

# คำสั่งรัน Flask ผ่าน Gunicorn โดยชี้ไปที่ Port 7860 (แก้เป็น server:app)
CMD ["gunicorn", "-b", "0.0.0.0:7860", "server:app", "--timeout", "120", "--workers", "1", "--threads", "2"]
</file>

