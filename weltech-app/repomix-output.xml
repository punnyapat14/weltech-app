                                <tr><td colSpan="4" className="p-10 text-center opacity-50">กำลังโหลดข้อมูล...</td></tr>
                            ) : filteredUsers.length > 0 ? (
                                filteredUsers.map((u) => {
                                    const isShow = showPassMap[u.id];
